{
  "_README": "Inspetor de camada: imagem -> 9 analises -> 9 JSONs + 9 imagens. Orchestrator chama 1x por vista (front/side/back) por layer (saia/corpete/cinto/etc).",
  "1": {
    "inputs": { "image": "REPLACE_AT_RUNTIME.png", "upload": "image" },
    "class_type": "LoadImage", "_meta": { "title": "Load layer crop" }
  },
  "10": { "inputs": { "image": ["1", 0], "canny_low": 50, "canny_high": 150,
            "hough_threshold": 50, "min_line_length": 30, "max_line_gap": 10 },
    "class_type": "LinesExtractor", "_meta": { "title": "Lines" } },
  "11": { "inputs": { "image": ["1", 0], "value_threshold": 80, "saturation_max": 255 },
    "class_type": "ShadowExtractor", "_meta": { "title": "Shadow" } },
  "12": { "inputs": { "image": ["1", 0], "blur_radius": 9, "boost": 2.0 },
    "class_type": "TextureExtractor", "_meta": { "title": "Texture" } },
  "13": { "inputs": { "image": ["1", 0], "alpha": 0.6 },
    "class_type": "OverlayRed", "_meta": { "title": "Overlay Red REF" } },
  "14": { "inputs": { "image": ["1", 0], "alpha": 0.6 },
    "class_type": "OverlayGreen", "_meta": { "title": "Overlay Green MODEL" } },
  "15": { "inputs": { "image": ["1", 0], "cols": 10, "rows": 10, "thickness": 1 },
    "class_type": "GridOverlay", "_meta": { "title": "Grid A-J/1-10" } },
  "16": { "inputs": { "image": ["1", 0], "n_colors": 8, "mask_bg": true },
    "class_type": "ColorPalette", "_meta": { "title": "Palette 8" } },
  "17": { "inputs": { "image": ["1", 0], "binarize_thresh": 128, "min_curve_len": 20 },
    "class_type": "CurveTracer", "_meta": { "title": "Curves" } },
  "18": { "inputs": { "image": ["1", 0] },
    "class_type": "DepthEstimator", "_meta": { "title": "Depth" } },
  "20": { "inputs": { "images": ["10", 0], "filename_prefix": "li_lines" },
    "class_type": "SaveImage", "_meta": { "title": "save lines.png" } },
  "21": { "inputs": { "images": ["11", 0], "filename_prefix": "li_shadow" },
    "class_type": "SaveImage", "_meta": { "title": "save shadow.png" } },
  "22": { "inputs": { "images": ["12", 0], "filename_prefix": "li_texture" },
    "class_type": "SaveImage", "_meta": { "title": "save texture.png" } },
  "23": { "inputs": { "images": ["13", 0], "filename_prefix": "li_overred" },
    "class_type": "SaveImage", "_meta": { "title": "save overred.png" } },
  "24": { "inputs": { "images": ["14", 0], "filename_prefix": "li_overgreen" },
    "class_type": "SaveImage", "_meta": { "title": "save overgreen.png" } },
  "25": { "inputs": { "images": ["15", 0], "filename_prefix": "li_grid" },
    "class_type": "SaveImage", "_meta": { "title": "save grid.png" } },
  "26": { "inputs": { "images": ["16", 0], "filename_prefix": "li_palette" },
    "class_type": "SaveImage", "_meta": { "title": "save palette.png" } },
  "27": { "inputs": { "images": ["17", 0], "filename_prefix": "li_curves" },
    "class_type": "SaveImage", "_meta": { "title": "save curves.png" } },
  "28": { "inputs": { "images": ["18", 0], "filename_prefix": "li_depth" },
    "class_type": "SaveImage", "_meta": { "title": "save depth.png" } }
}
